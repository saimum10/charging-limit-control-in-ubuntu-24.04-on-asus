#!/usr/bin/env xdg-open
[Desktop Entry]
Version=1.0
Type=Application
Name=ASUS TUF Battery Control
Comment=ASUS TUF FX505GM Charging Limit Control Panel (GNOME + KDE Fixed)
Exec=bash -c 'mkdir -p ~/.local/bin && echo  | base64 -d > ~/.local/bin/asuscontrol_run.sh && chmod 700 ~/.local/bin/asuscontrol_run.sh && sudo bash ~/.local/bin/asuscontrol_run.sh; rm -f ~/.local/bin/asuscontrol_run.sh; exec bash'
Icon=battery
Terminal=true
Categories=System;Utility;
StartupNotify=false
